<Application x:Class="WitpaeTheaterStaff.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <!-- Dark theme base colours -->
        <SolidColorBrush x:Key="AppBackground"    Color="#1A2A3A"/>
        <SolidColorBrush x:Key="ToolbarBackground" Color="#2D4A6A"/>
        <SolidColorBrush x:Key="StatusBackground"  Color="#1A2A3A"/>
        <SolidColorBrush x:Key="AppForeground"    Color="#D8E8F8"/>
    </Application.Resources>
</Application>
