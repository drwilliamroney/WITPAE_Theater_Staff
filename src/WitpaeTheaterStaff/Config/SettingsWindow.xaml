<Window x:Class="WitpaeTheaterStaff.Config.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="WITPAE Theater Staff — Settings"
        Width="580" Height="320"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False">

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="150"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="70"/>
        </Grid.ColumnDefinitions>

        <!-- Game directory -->
        <Label Grid.Row="0" Grid.Column="0" Content="Game directory:" VerticalAlignment="Center"/>
        <TextBox Grid.Row="0" Grid.Column="1" x:Name="GameDirBox" Margin="0,3" VerticalAlignment="Center"/>
        <Button Grid.Row="0" Grid.Column="2" Content="Browse…" Margin="4,3,0,3"
                Click="BrowseGameDir_Click"/>

        <!-- Save directory -->
        <Label Grid.Row="1" Grid.Column="0" Content="Save directory:" VerticalAlignment="Center"/>
        <TextBox Grid.Row="1" Grid.Column="1" x:Name="SaveDirBox" Margin="0,3" VerticalAlignment="Center"/>
        <Button Grid.Row="1" Grid.Column="2" Content="Browse…" Margin="4,3,0,3"
                Click="BrowseSaveDir_Click"/>

        <!-- Start-of-day file -->
        <Label Grid.Row="2" Grid.Column="0" Content="Start-of-day file:" VerticalAlignment="Center"/>
        <TextBox Grid.Row="2" Grid.Column="1" x:Name="SodFileBox" Margin="0,3" VerticalAlignment="Center"/>
        <Button Grid.Row="2" Grid.Column="2" Content="Browse…" Margin="4,3,0,3"
                Click="BrowseSod_Click"/>

        <!-- End-of-day file -->
        <Label Grid.Row="3" Grid.Column="0" Content="End-of-day file:" VerticalAlignment="Center"/>
        <TextBox Grid.Row="3" Grid.Column="1" x:Name="EodFileBox" Margin="0,3" VerticalAlignment="Center"/>
        <Button Grid.Row="3" Grid.Column="2" Content="Browse…" Margin="4,3,0,3"
                Click="BrowseEod_Click"/>

        <!-- Side -->
        <Label Grid.Row="4" Grid.Column="0" Content="Side:" VerticalAlignment="Center"/>
        <ComboBox Grid.Row="4" Grid.Column="1" x:Name="SideCombo" Margin="0,3"
                  HorizontalAlignment="Left" Width="100">
            <ComboBoxItem Content="ALLIED"/>
            <ComboBoxItem Content="JAPAN"/>
        </ComboBox>

        <!-- Buttons -->
        <StackPanel Grid.Row="6" Grid.Column="0" Grid.ColumnSpan="3"
                    Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
            <Button Content="Save" Width="75" Margin="4,0" Click="Save_Click"
                    IsDefault="True"/>
            <Button Content="Cancel" Width="75" Margin="4,0" Click="Cancel_Click"
                    IsCancel="True"/>
        </StackPanel>
    </Grid>
</Window>
