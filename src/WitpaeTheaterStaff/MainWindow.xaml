<Window x:Class="WitpaeTheaterStaff.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="clr-namespace:WitpaeTheaterStaff.UI"
        Title="WITPAE Theater Staff"
        Height="768" Width="1280"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource AppBackground}">

    <DockPanel>

        <!-- ── Menu bar ──────────────────────────────────────────────── -->
        <Menu DockPanel.Dock="Top" Background="{StaticResource ToolbarBackground}">
            <MenuItem Header="_File" Foreground="{StaticResource AppForeground}">
                <MenuItem Header="_Settings…"  Click="Settings_Click"/>
                <Separator/>
                <MenuItem Header="_Reload Data" Click="Reload_Click" InputGestureText="F5"/>
                <Separator/>
                <MenuItem Header="E_xit" Click="Exit_Click" InputGestureText="Alt+F4"/>
            </MenuItem>
        </Menu>

        <!-- ── Toolbar ───────────────────────────────────────────────── -->
        <ToolBar DockPanel.Dock="Top"
                 Background="{StaticResource ToolbarBackground}"
                 Foreground="{StaticResource AppForeground}">

            <Label Content="Side:" Foreground="{StaticResource AppForeground}"/>
            <ComboBox x:Name="SideCombo" Width="80"
                      SelectionChanged="SideCombo_SelectionChanged">
                <ComboBoxItem Content="ALLIED" IsSelected="True"/>
                <ComboBoxItem Content="JAPAN"/>
            </ComboBox>

            <Separator/>
            <Label x:Name="TurnLabel"  Content="Turn: —"  Foreground="{StaticResource AppForeground}"/>
            <Label x:Name="DateLabel"  Content="Date: —"  Foreground="{StaticResource AppForeground}"/>

            <Separator/>
            <Label Content="Overlays:" Foreground="{StaticResource AppForeground}"/>

            <ToggleButton x:Name="ToggleRegions"    Content="Regions"      IsChecked="True"
                          Tag="overlay_region"  Click="OverlayToggle_Click" Margin="2,0"/>
            <ToggleButton x:Name="ToggleTF"         Content="Task Forces"  IsChecked="True"
                          Tag="overlay_tf"      Click="OverlayToggle_Click" Margin="2,0"/>
            <ToggleButton x:Name="ToggleShips"      Content="Ships"        IsChecked="False"
                          Tag="overlay_ship"    Click="OverlayToggle_Click" Margin="2,0"/>
            <ToggleButton x:Name="ToggleBases"      Content="Bases"        IsChecked="True"
                          Tag="overlay_base"    Click="OverlayToggle_Click" Margin="2,0"/>
            <ToggleButton x:Name="ToggleAir"        Content="Air"          IsChecked="True"
                          Tag="overlay_air"     Click="OverlayToggle_Click" Margin="2,0"/>
            <ToggleButton x:Name="ToggleLand"       Content="Land"         IsChecked="True"
                          Tag="overlay_land"    Click="OverlayToggle_Click" Margin="2,0"/>
            <ToggleButton x:Name="ToggleThreats"    Content="Threats"      IsChecked="True"
                          Tag="overlay_threat"  Click="OverlayToggle_Click" Margin="2,0"/>

            <Separator/>
            <Button Content="↺ Reload" Click="Reload_Click" Padding="6,2"/>
        </ToolBar>

        <!-- ── Status bar ────────────────────────────────────────────── -->
        <StatusBar DockPanel.Dock="Bottom"
                   Background="{StaticResource StatusBackground}"
                   Foreground="{StaticResource AppForeground}">
            <StatusBarItem>
                <TextBlock x:Name="ShipCountLabel"  Text="Ships: —"/>
            </StatusBarItem>
            <Separator/>
            <StatusBarItem>
                <TextBlock x:Name="AirCountLabel"   Text="Air: —"/>
            </StatusBarItem>
            <Separator/>
            <StatusBarItem>
                <TextBlock x:Name="LandCountLabel"  Text="Land: —"/>
            </StatusBarItem>
            <Separator/>
            <StatusBarItem>
                <TextBlock x:Name="BaseCountLabel"  Text="Bases: —"/>
            </StatusBarItem>
            <Separator/>
            <StatusBarItem>
                <TextBlock x:Name="WatchLabel"      Text="Watching: —"/>
            </StatusBarItem>
        </StatusBar>

        <!-- ── Main content: map + detail panel ──────────────────────── -->
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" MinWidth="400"/>
                <ColumnDefinition Width="5"/>
                <ColumnDefinition Width="320" MinWidth="180"/>
            </Grid.ColumnDefinitions>

            <!-- Scrollable, zoomable map area -->
            <ScrollViewer Grid.Column="0"
                          x:Name="MapScrollViewer"
                          HorizontalScrollBarVisibility="Auto"
                          VerticalScrollBarVisibility="Auto"
                          PreviewMouseWheel="MapScrollViewer_PreviewMouseWheel"
                          Background="#0A1520">
                <Canvas x:Name="MapCanvas"
                        Background="Transparent"
                        MouseMove="MapCanvas_MouseMove"
                        MouseLeave="MapCanvas_MouseLeave"
                        MouseLeftButtonUp="MapCanvas_MouseLeftButtonUp">
                    <!-- Map image and overlay canvases are added in code-behind -->
                </Canvas>
            </ScrollViewer>

            <!-- Resize splitter -->
            <GridSplitter Grid.Column="1"
                          Width="5"
                          HorizontalAlignment="Stretch"
                          VerticalAlignment="Stretch"
                          ResizeBehavior="PreviousAndNext"
                          Background="#2D4A6A"/>

            <!-- Detail panel -->
            <ui:DetailPanel Grid.Column="2" x:Name="DetailPanel"/>
        </Grid>

    </DockPanel>
</Window>
