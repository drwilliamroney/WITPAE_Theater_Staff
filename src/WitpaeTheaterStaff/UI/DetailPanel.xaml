<UserControl x:Class="WitpaeTheaterStaff.UI.DetailPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#2D4A6A" Padding="6,4">
            <TextBlock x:Name="PanelTitle"
                       Text="Detail"
                       Foreground="White"
                       FontWeight="SemiBold"
                       FontSize="12"/>
        </Border>

        <ListView Grid.Row="1"
                  x:Name="DetailList"
                  BorderThickness="0"
                  Background="#1E2D3D"
                  Foreground="#D8E8F8"
                  FontSize="11"
                  FontFamily="Consolas">
            <ListView.View>
                <GridView>
                    <GridViewColumn Header="Field" Width="110"
                                    DisplayMemberBinding="{Binding Label}"/>
                    <GridViewColumn Header="Value" Width="185"
                                    DisplayMemberBinding="{Binding Value}"/>
                </GridView>
            </ListView.View>
        </ListView>
    </Grid>

</UserControl>
